# PostgreSQL
POSTGRES_USER="postgres_username"
POSTGRES_PASSWORD="strong_postgres_password"
POSTGRES_DB="default_database_name"

# Redis
REDIS_PASSWORD="strong_redis_password"

# MinIO
MINIO_ROOT_USER="minio_admin_username"
MINIO_ROOT_PASSWORD="strong_minio_password"

# Grafana
GRAFANA_ADMIN_USER="grafana_admin_username"
GRAFANA_ADMIN_PASSWORD="strong_grafana_password"

# LiteLLM
LITELLM_ADMIN_PASS="sk-your-litellm-master-key"

# MongoDB
MONGO_INITDB_ROOT_USERNAME="mongo_admin_username"
MONGO_INITDB_ROOT_PASSWORD="strong_mongo_password"
MONGO_INITDB_DATABASE="default_database_name"

# External API Keys (fill in for real usage)
OPENAI_API_KEY="sk-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# ─── Ports (host-side, change if conflicts) ─────────────────────────────
POSTGRES_PORT=5432
REDIS_PORT=6379
MONGODB_PORT=27017
MONGO_EXPRESS_PORT=8081
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CHROMADB_PORT=8000
MLFLOW_PORT=5000
LITELLM_PORT=4000
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8889
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
REDISINSIGHT_PORT=5540
CHROMADB_ADMIN_PORT=3010
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080
PORTAINER_PORT=9443
